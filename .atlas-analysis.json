  "keyFeatures": [
    "Provision dedicated Nigerian bank account numbers (DVAs) per customer",
    "Automatic ledger crediting on inbound NIP payments via webhooks",
    "Outbound bank transfers to any Nigerian bank account",
    "Full double-entry ledger with balance and transaction history",
    "HMAC-SHA256 webhook signature verification",
    "Periodic reconciliation sweeps against Nomba settlement records",
    "KYC tiered customer management (Tier 1–3)",
    "Idempotent operations — no duplicate accounts or double credits"
  ],
